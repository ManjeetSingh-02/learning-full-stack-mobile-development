{
  "expo": {
    "name": "expo_notifications",
    "slug": "expo_notifications",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "exponotifications",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.manjeetsingh02.expo_notifications.dev"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3299a8",
          "defaultChannel": "default",
          "sounds": ["./assets/sound.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
